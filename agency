#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"
export DOCKER_CONFIG="$ROOT_DIR/.cache/docker-config"
export DOCKER_CLI_PLUGIN_EXTRA_DIRS="${HOME}/.docker/cli-plugins"
export DOCKER_HOST="unix://${HOME}/.docker/run/docker.sock"

mkdir -p "$DOCKER_CONFIG"
mkdir -p "$DOCKER_CONFIG/cli-plugins"
for plugin in docker-buildx docker-compose; do
  target="/Applications/Docker.app/Contents/Resources/cli-plugins/$plugin"
  if [[ -x "$target" ]]; then
    ln -sf "$target" "$DOCKER_CONFIG/cli-plugins/$plugin"
  fi
done

compose() {
  docker compose "$@"
}

run_dev() {
  compose run --rm dev "$@"
}

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  help|-h|--help)
    cat <<'USAGE'
Usage:
  ./agency bootstrap          Install workspace dependencies in the container
  ./agency doctor            Run environment checks inside the container
  ./agency index [args...]   Build or refresh the local code index
  ./agency task "prompt"     Run one agent task
  ./agency chat              Start an interactive chat session
  ./agency web               Start the local browser console
  ./agency up                Start the long-running dev container
  ./agency down              Stop the compose service
  ./agency shell             Open a shell in the dev container
  ./agency clean             Remove compose resources and project caches
  ./agency purge             Clean plus delete .env.local
USAGE
    ;;
  bootstrap)
    compose run --rm --build dev pnpm bootstrap
    ;;
  doctor|index|task|chat)
    run_dev pnpm agency "$cmd" "$@"
    ;;
  web)
    compose run --rm --service-ports dev pnpm agency "$cmd" "$@"
    ;;
  up)
    compose up -d --build dev
    ;;
  down)
    compose down --remove-orphans
    ;;
  shell)
    compose run --rm dev bash
    ;;
  clean)
    exec "$ROOT_DIR/scripts/clean.sh"
    ;;
  purge)
    exec "$ROOT_DIR/scripts/purge.sh"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    exit 1
    ;;
esac
